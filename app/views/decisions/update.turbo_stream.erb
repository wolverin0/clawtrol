<%# Remove task from queue after action %>
<%= turbo_stream.remove "task_#{@task.id}" %>

<%# Update count or show empty state %>
<%= turbo_stream.update "decisions_queue" do %>
  <% remaining_tasks = Task.where(user: current_user, status: :needs_decision).order(created_at: :asc) %>
  <%= render remaining_tasks %>

  <% if remaining_tasks.empty? %>
    <div class="text-center py-12 text-content-muted">
      <svg class="w-16 h-16 mx-auto mb-4 opacity-30" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <p class="text-lg mb-2">No tasks need attention</p>
      <p class="text-sm">Tasks that fail 3 times will appear here</p>
    </div>
  <% end %>
<% end %>

<%# Show flash message %>
<%= turbo_stream.update "flash-messages" do %>
  <% if flash[:notice] %>
    <div data-controller="flash" class="py-1 px-2.5 bg-status-success/20 text-status-success text-xs font-medium rounded-md">
      <%= flash[:notice] %>
    </div>
  <% elsif flash[:alert] %>
    <div data-controller="flash" class="py-1 px-2.5 bg-status-error/20 text-status-error text-xs font-medium rounded-md">
      <%= flash[:alert] %>
    </div>
  <% end %>
<% end %>
