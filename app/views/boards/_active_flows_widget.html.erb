<div class="px-4 md:px-6 py-2 border-b border-border"
     data-controller="active-flows"
     data-active-flows-api-base-value="/api/v1"
     data-active-flows-interval-value="15000"
     data-active-flows-collapsed-value="true">
  <button class="w-full flex items-center justify-between text-xs group"
          data-action="active-flows#toggle" type="button">
    <div class="flex items-center gap-2">
      <span class="text-content-muted">⚡ Active Flows & Runs</span>
      <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-accent/20 text-accent text-[10px] font-bold hidden"
            data-active-flows-target="badge">0</span>
    </div>
    <svg class="w-4 h-4 text-content-muted transition-transform duration-200"
         data-active-flows-target="toggleIcon"
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>
  <div class="hidden mt-2 space-y-3" data-active-flows-target="content">
    <div class="flex items-center gap-4 text-xs text-content-muted" data-active-flows-target="statsBar">
      <span class="animate-pulse">Loading...</span>
    </div>
    <div>
      <h4 class="text-[10px] font-semibold text-content-muted uppercase tracking-wider mb-1">Flows</h4>
      <div class="space-y-1" data-active-flows-target="flowsList">
        <p class="text-xs text-content-muted italic">Loading...</p>
      </div>
    </div>
    <div>
      <h4 class="text-[10px] font-semibold text-content-muted uppercase tracking-wider mb-1">Background Runs</h4>
      <div class="space-y-1" data-active-flows-target="runsList">
        <p class="text-xs text-content-muted italic">Loading...</p>
      </div>
    </div>
  </div>
</div>
