<%# Mobile Navigation Menu - Full screen overlay %>
<div data-controller="mobile-nav">
  <%# Hamburger button - visible only on mobile %>
  <button type="button"
          data-action="click->mobile-nav#open"
          class="md:hidden w-10 h-10 rounded-md bg-bg-elevated hover:bg-bg-hover flex items-center justify-center text-lg transition-colors cursor-pointer"
          title="Navigation menu">
    ☰
  </button>

  <%# Full-screen overlay panel %>
  <div data-mobile-nav-target="panel"
       data-action="click->mobile-nav#closeOnOverlay"
       class="hidden fixed inset-0 z-[200] bg-black/70">
    <div class="absolute right-0 top-0 bottom-0 w-72 bg-bg-base border-l border-border overflow-y-auto">
      <%# Header %>
      <div class="flex items-center justify-between px-4 py-3 border-b border-border">
        <span class="text-sm font-semibold text-content font-display">🦞 Navigation</span>
        <button type="button"
                data-action="click->mobile-nav#close"
                class="w-10 h-10 rounded-md hover:bg-bg-elevated flex items-center justify-center text-lg text-content-muted hover:text-content transition-colors cursor-pointer">
          ✕
        </button>
      </div>

      <%# Navigation links %>
      <nav class="py-2">
        <% primary_navigation.each do |category| %>
          <div class="px-4 py-2 mt-2 text-[10px] font-bold uppercase tracking-wider text-content-muted opacity-70">
            <%= category[:icon] %> <%= category[:label] %>
          </div>
          <% category[:items].each do |item| %>
            <% if item[:type] == :separator %>
              <div class="border-t border-border my-2"></div>
            <% elsif item[:type] == :label %>
              <div class="px-4 py-1 mt-1 text-[10px] font-bold uppercase tracking-wider text-content-muted opacity-70">
                <%= item[:text] %>
              </div>
            <% else %>
              <% is_active = nav_item_active?(item) %>
              <% active_class = is_active ? "text-accent bg-accent/10" : "text-content-secondary hover:bg-bg-elevated hover:text-content" %>
              
              <% if item[:external] %>
                <%= link_to item[:url], target: "_blank", rel: "noopener noreferrer", class: "flex items-center gap-3 px-4 py-3 text-sm transition-colors #{active_class}" do %>
                  <span class="text-lg w-7 text-center"><%= item[:icon] %></span> <%= item[:label] %>
                <% end %>
              <% else %>
                <%= link_to item[:url], class: "flex items-center gap-3 px-4 py-3 text-sm transition-colors #{active_class}" do %>
                  <span class="text-lg w-7 text-center"><%= item[:icon] %></span> 
                  <span class="flex-1"><%= item[:label] %></span>
                  <% if item[:badge] %>
                    <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-accent/20 text-accent">
                      <%= item[:badge] %>
                    </span>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <div class="border-t border-border my-2"></div>

        <%= link_to settings_path, class: "flex items-center gap-3 px-4 py-3 text-sm text-content-secondary hover:bg-bg-elevated hover:text-content transition-colors" do %>
          <span class="text-lg w-7 text-center">⚙️</span> Settings
        <% end %>
      </nav>
    </div>
  </div>
</div>