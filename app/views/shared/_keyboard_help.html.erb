<%# Keyboard Shortcuts Help Modal %>
<div id="keyboard-shortcuts-help"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
     tabindex="-1"
     role="dialog"
     aria-labelledby="keyboard-shortcuts-title"
     aria-modal="true"
     data-controller="modal"
     data-modal-target="container">
  <%# Backdrop %>
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"
       data-action="click->modal#close"></div>

  <%# Modal Content %>
  <div class="relative bg-bg-surface border border-border rounded-xl shadow-2xl shadow-black/50 w-full max-w-lg overflow-hidden max-h-[80vh] flex flex-col">
    <%# Header %>
    <div class="flex items-center justify-between px-5 py-4 border-b border-border shrink-0">
      <h2 id="keyboard-shortcuts-title" class="text-lg font-display font-semibold text-content">
        ⌨️ Keyboard Shortcuts
      </h2>
      <button type="button"
              data-action="click->modal#close"
              class="text-content-muted hover:text-content transition-colors p-1 rounded-lg hover:bg-bg-elevated"
              aria-label="Close shortcuts modal">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%# Shortcuts List — scrollable %>
    <div class="p-5 space-y-4 overflow-y-auto">
      <%# Navigation %>
      <div class="space-y-2">
        <h3 class="text-xs font-semibold text-content-muted uppercase tracking-wider">Navigation</h3>
        
        <% [
          ["Command palette", ["⌘/Ctrl", "K"]],
          ["Focus search", ["/"]],
          ["Go to Boards", ["g", "then", "b"]],
          ["Go to Cron Jobs", ["g", "then", "c"]],
          ["Go to System", ["g", "then", "s"]],
        ].each do |label, keys| %>
          <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-bg-elevated/50">
            <span class="text-sm text-content"><%= label %></span>
            <div class="flex items-center gap-1">
              <% keys.each_with_index do |key, i| %>
                <% if key == "then" %>
                  <span class="text-content-muted text-xs mx-0.5">then</span>
                <% else %>
                  <kbd class="px-2 py-1 text-xs font-mono font-semibold text-content bg-bg-base border border-border rounded shadow-sm"><%= key %></kbd>
                  <% if i < keys.size - 1 && keys[i+1] != "then" %>
                    <span class="text-content-muted">+</span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Board Actions %>
      <div class="space-y-2">
        <h3 class="text-xs font-semibold text-content-muted uppercase tracking-wider">Board Actions</h3>

        <% [
          ["New task (focus input)", ["n"]],
          ["Toggle agent terminal", ["Ctrl", "/"]],
        ].each do |label, keys| %>
          <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-bg-elevated/50">
            <span class="text-sm text-content"><%= label %></span>
            <div class="flex items-center gap-1">
              <% keys.each_with_index do |key, i| %>
                <kbd class="px-2 py-1 text-xs font-mono font-semibold text-content bg-bg-base border border-border rounded shadow-sm"><%= key %></kbd>
                <% if i < keys.size - 1 %>
                  <span class="text-content-muted">+</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# General %>
      <div class="space-y-2">
        <h3 class="text-xs font-semibold text-content-muted uppercase tracking-wider">General</h3>

        <% [
          ["Show this help", ["?"]],
          ["Close modal/panel", ["Esc"]],
          ["Toggle theme", ["via ⌘K → Theme"]],
        ].each do |label, keys| %>
          <div class="flex items-center justify-between py-2 px-3 rounded-lg bg-bg-elevated/50">
            <span class="text-sm text-content"><%= label %></span>
            <div class="flex items-center gap-1">
              <% keys.each do |key| %>
                <kbd class="px-2 py-1 text-xs font-mono font-semibold text-content bg-bg-base border border-border rounded shadow-sm"><%= key %></kbd>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Tip %>
      <div class="pt-3 mt-2 border-t border-border">
        <p class="text-xs text-content-muted text-center">
          💡 Shortcuts are disabled when typing in text fields
        </p>
      </div>
    </div>
  </div>
</div>
